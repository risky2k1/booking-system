header.bg-white.shadow-sm.sticky.top-0.z-50
  nav.max-w-7xl.mx-auto(class="px-4 sm:px-6 lg:px-8")
    .flex.items-center.justify-between.h-20
      a.font-serif.text-2xl.font-bold.text-primary(href="/", class="hover:text-primary/90 transition-colors cursor-pointer") Grand Hotel
      .hidden(class="md:flex items-center gap-8")
        a.text-slate-600.font-medium(href="/", class="hover:text-primary transition-colors cursor-pointer") Home
        a.text-slate-600.font-medium(href="/rooms", class="hover:text-primary transition-colors cursor-pointer") Rooms
        a.text-slate-600.font-medium(href="/about", class="hover:text-primary transition-colors cursor-pointer") About
        a.text-slate-600.font-medium(href="/contact", class="hover:text-primary transition-colors cursor-pointer") Contact
      div(class="md:hidden")
        button#mobile-menu-btn.p-2.rounded-lg(class="hover:bg-slate-100 text-slate-600 cursor-pointer", type="button", aria-label="Menu")
          svg.w-6.h-6(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke="currentColor")
            path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M4 6h16M4 12h16M4 18h16")
  #mobile-menu.hidden(class="md:hidden border-t border-slate-200 bg-white px-4 py-4")
    .flex.flex-col.gap-4
      a.text-slate-600.font-medium(href="/", class="hover:text-primary transition-colors cursor-pointer") Home
      a.text-slate-600.font-medium(href="/rooms", class="hover:text-primary transition-colors cursor-pointer") Rooms
      a.text-slate-600.font-medium(href="/about", class="hover:text-primary transition-colors cursor-pointer") About
      a.text-slate-600.font-medium(href="/contact", class="hover:text-primary transition-colors cursor-pointer") Contact
  script.
    document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
      document.getElementById('mobile-menu').classList.toggle('hidden');
    });
