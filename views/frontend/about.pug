extends layouts/layout
block content
  section.relative.h-80.flex.items-center.justify-center
    .absolute.inset-0
      img.w-full.h-full.object-cover(src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1920", alt="About")
      .absolute.inset-0(class="bg-primary/60")
    .relative.z-10.text-center.px-4
      h1.font-serif.text-5xl.font-bold.text-white.mb-2 About Us
      p(class="text-xl text-white/90") Our story of excellence

  section.py-24.px-4
    .max-w-4xl.mx-auto
      h2.font-serif.text-3xl.font-bold.text-slate-800.mb-6 Our Heritage
      p.text-slate-600.mb-6 Since 1920, Grand Hotel has welcomed discerning travelers to our shores. Nestled between the ocean and lush gardens, we offer an unparalleled blend of timeless elegance and modern comfort.
      p.text-slate-600.mb-6 Our commitment to excellence extends to every detail—from our hand-selected furnishings to our world-class culinary experiences. Each stay is crafted to create lasting memories.
      p.text-slate-600 We invite you to discover why generations of guests have made Grand Hotel their destination of choice.
