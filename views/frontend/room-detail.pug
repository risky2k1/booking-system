extends layouts/layout
block content
  section.px-4.pt-8.pb-16
    .max-w-7xl.mx-auto
      .grid(class="grid-cols-1 lg:grid-cols-2 gap-12")
        .space-y-4
          .rounded-2xl.overflow-hidden.shadow-lg
            img.w-full.h-96.object-cover(src=room.images[0], alt=room.name)
          .grid.grid-cols-2.gap-4
            each img, i in room.images.slice(1, 3)
              .rounded-xl.overflow-hidden.shadow-md
                img.w-full.h-48.object-cover(src=img, alt=room.name + " " + (i + 2))
        div
          +badge("Available")
          h1.font-serif.text-4xl.font-bold.text-slate-800.mt-4.mb-4= room.name
          p.text-slate-600.mb-6= room.description
          h3.font-semibold.text-slate-800.mb-3 Amenities
          ul.grid.grid-cols-2.gap-2.mb-8
            each a in room.amenities
              li.flex.items-center.gap-2.text-slate-600
                svg.w-5.h-5.text-accent(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke="currentColor")
                  path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M5 13l4 4L19 7")
                span= a
          .flex.items-center.justify-between.pt-6.border-t.border-slate-200
            div
              span.font-semibold.text-2xl.text-primary $#{room.price}
              span.text-slate-500  /night
              if room.weekday && room.weekend && Math.round(room.weekday) !== Math.round(room.weekend)
                p.text-sm.text-slate-500.mt-1
                  | Weekday: $#{room.weekday} · Weekend: $#{room.weekend}
            +button("Book Now", "/booking/" + room.slug)
