extends ../layouts/layout

block content
  .flex.gap-8
    aside.w-56.flex-shrink-0(class="hidden lg:block")
      nav.space-y-1.sticky.top-24
        h3.text-xs.font-semibold.text-slate-500.uppercase.tracking-wider.mb-3 Documentation
        each item in docNav
          a.block.px-3.py-2.rounded-lg.text-sm(class=(item.id === currentDoc ? 'bg-slate-200 text-slate-900 font-medium' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'), href=item.href)= item.title
    article.flex-1.min-w-0
      .prose-docs.max-w-none
        | !{docContent}
