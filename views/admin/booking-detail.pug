extends layouts/layout

block content
  .mb-6
    a.inline-flex.items-center.text-sm.text-slate-600.mb-4(class="hover:text-slate-900", href="/admin/bookings")
      svg.w-4.h-4.mr-1(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke="currentColor")
        path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M15 19l-7-7 7-7")
      Back to Bookings
    h1.text-2xl.font-semibold.text-slate-900 Booking ##{booking.id}
  .bg-white.rounded-xl.border.border-slate-200.shadow-sm.overflow-hidden
    .p-6.space-y-4
      div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
        .py-2
          p.text-xs.font-medium.text-slate-500 Guest name
          p.text-sm.font-medium.text-slate-900= booking.guestName
        .py-2
          p.text-xs.font-medium.text-slate-500 Room
          p.text-sm.font-medium.text-slate-900= booking.roomName
        .py-2
          p.text-xs.font-medium.text-slate-500 Check-in
          p.text-sm.font-medium.text-slate-900= booking.checkIn
        .py-2
          p.text-xs.font-medium.text-slate-500 Check-out
          p.text-sm.font-medium.text-slate-900= booking.checkOut
        .py-2
          p.text-xs.font-medium.text-slate-500 Status
          p
            +badge(booking.status)
        .py-2
          p.text-xs.font-medium.text-slate-500 Total
          p.text-sm.font-medium.text-slate-900 $#{booking.total}
    .px-6.py-4.bg-slate-50.border-t.border-slate-200
      p.text-sm.text-slate-600.mb-2 Update status
      .flex.gap-2.flex-wrap
        button#btn-confirmed(class="px-3 py-1.5 rounded-lg text-sm font-medium bg-emerald-100 text-emerald-800 hover:bg-emerald-200", data-status="confirmed") Confirmed
        button#btn-pending(class="px-3 py-1.5 rounded-lg text-sm font-medium bg-amber-100 text-amber-800 hover:bg-amber-200", data-status="pending") Pending
        button#btn-cancelled(class="px-3 py-1.5 rounded-lg text-sm font-medium bg-slate-100 text-slate-600 hover:bg-slate-200", data-status="cancelled") Cancelled
  script.
    var bookingId = '#{booking.id}';
    ['btn-confirmed','btn-pending','btn-cancelled'].forEach(function(id) {
      document.getElementById(id).addEventListener('click', function() {
        var status = this.getAttribute('data-status');
        fetch('/admin/bookings/' + bookingId, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: status })
        }).then(function(r) { return r.json(); }).then(function(data) {
          var badge = document.querySelector('.inline-flex.items-center.px-2');
          if (badge) { badge.textContent = status; badge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ' + (status === 'confirmed' ? 'bg-emerald-100 text-emerald-800' : status === 'pending' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-600'); }
        });
      });
    });
