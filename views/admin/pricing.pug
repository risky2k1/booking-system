extends layouts/layout

block content
  .mb-8
    h1.text-2xl.font-semibold.text-slate-900 Pricing
    p.text-slate-600.mt-1 Set weekday and weekend rates by room
  .bg-white.rounded-xl.border.border-slate-200.shadow-sm.overflow-hidden
    .overflow-x-auto
      table.min-w-full.divide-y.divide-slate-200
        thead.bg-slate-50
          tr
            th.px-6.py-4.text-left.text-xs.font-medium.text-slate-500.uppercase.tracking-wider Room
            th.px-6.py-4.text-left.text-xs.font-medium.text-slate-500.uppercase.tracking-wider Weekday
            th.px-6.py-4.text-left.text-xs.font-medium.text-slate-500.uppercase.tracking-wider Weekend
            th.px-6.py-4.text-right.text-xs.font-medium.text-slate-500.uppercase.tracking-wider
        tbody.divide-y.divide-slate-200
          each p in pricing
            tr(class="hover:bg-slate-50")
              td.px-6.py-4.text-sm.font-medium.text-slate-900= p.roomName
              td.px-6.py-4.text-sm.text-slate-700 $#{p.weekday}
              td.px-6.py-4.text-sm.text-slate-700 $#{p.weekend}
              td.px-6.py-4.text-right
                button.pricing-edit.text-indigo-600.text-sm.font-medium(class="hover:text-indigo-800", data-room-id=p.roomId, data-room-name=p.roomName, data-weekday=p.weekday, data-weekend=p.weekend) Edit
    .p-6.border-t.border-slate-200
      h3.text-sm.font-medium.text-slate-900.mb-3 Update price
      form#pricing-form.flex.flex-wrap.gap-4.items-end(method="post", action="/admin/pricing")
        input(type="hidden", name="roomId", id="pricing-roomId")
        input(type="hidden", name="roomName", id="pricing-roomName")
        div(class="flex-1 min-w-[120px]")
          label.block.text-xs.font-medium.text-slate-500.mb-1 Weekday ($)
          input#pricing-weekday.w-full.px-3.py-2.border.border-slate-300.rounded-lg(type="number", name="weekday", step="0.01", min="0", required)
        div(class="flex-1 min-w-[120px]")
          label.block.text-xs.font-medium.text-slate-500.mb-1 Weekend ($)
          input#pricing-weekend.w-full.px-3.py-2.border.border-slate-300.rounded-lg(type="number", name="weekend", step="0.01", min="0", required)
        button.px-4.py-2.rounded-lg.bg-indigo-600.text-white.text-sm.font-medium(class="hover:bg-indigo-700", type="submit") Save
  script.
    document.querySelectorAll('.pricing-edit').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.getElementById('pricing-roomId').value = this.getAttribute('data-room-id');
        document.getElementById('pricing-roomName').value = this.getAttribute('data-room-name');
        document.getElementById('pricing-weekday').value = this.getAttribute('data-weekday');
        document.getElementById('pricing-weekend').value = this.getAttribute('data-weekend');
      });
    });
