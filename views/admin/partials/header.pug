header.bg-white.border-b.border-slate-200.px-6.py-4.sticky.top-0.z-30
  .flex.items-center.justify-between
    button#sidebar-toggle.p-2.rounded-lg.hover:bg-slate-100.text-slate-600(type="button", aria-label="Toggle sidebar")
      svg.w-5.h-5(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke="currentColor")
        path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M4 6h16M4 12h16M4 18h16")
    .relative
      button#profile-toggle.flex.items-center.gap-3.p-2.rounded-lg.hover:bg-slate-100(type="button")
        .w-8.h-8.rounded-full.bg-indigo-600.flex.items-center.justify-center.text-white.text-sm.font-medium Admin
        span.text-sm.font-medium.text-slate-700.hidden.sm:inline Admin User
        svg.w-4.h-4.text-slate-500(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke="currentColor")
          path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M19 9l-7 7-7-7")
      #profile-dropdown.hidden.absolute.right-0.mt-2.w-48.bg-white.rounded-lg.shadow-lg.border.border-slate-200.py-1.z-50
        a.block.px-4.py-2.text-sm.text-slate-700.hover:bg-slate-100(href="#") Profile
        a.block.px-4.py-2.text-sm.text-slate-700.hover:bg-slate-100(href="#") Settings
        .border-t.border-slate-100
        a.block.px-4.py-2.text-sm.text-red-600.hover:bg-slate-100(href="/") Exit Admin
  script.
    document.getElementById('profile-toggle').addEventListener('click', function() {
      document.getElementById('profile-dropdown').classList.toggle('hidden');
    });
    document.getElementById('sidebar-toggle').addEventListener('click', function() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('sidebar').classList.toggle('lg:translate-x-0');
    });
