extends layouts/layout-auth

block content
  .w-full(class="max-w-md")
    .bg-white.rounded-xl.border.border-slate-200.shadow-sm.p-8
      .text-center.mb-8
        a.inline-block(href="/admin")
          span.text-2xl.font-semibold.text-slate-900 Admin
        p.text-slate-500.mt-2 Sign in to your account
      form#login-form.space-y-4(method="post", action="#")
        if error
          .p-3.rounded-lg.bg-red-50.text-red-700.text-sm= error
        div
          label.block.text-sm.font-medium.text-slate-700.mb-1(for="email") Email
          input#email.w-full.px-3.py-2.border.border-slate-300.rounded-lg.text-slate-900(type="email", name="email", required, autocomplete="email", placeholder="admin@example.com")
        div
          label.block.text-sm.font-medium.text-slate-700.mb-1(for="password") Password
          input#password.w-full.px-3.py-2.border.border-slate-300.rounded-lg.text-slate-900(type="password", name="password", required, autocomplete="current-password", placeholder="••••••••")
        button.w-full.px-4.py-2.rounded-lg.bg-indigo-600.text-white.font-medium(class="hover:bg-indigo-700", type="submit") Sign in
      p.text-center.text-sm.text-slate-500.mt-6
        | Don't have an account?
        a.ml-1.text-indigo-600.font-medium(class="hover:text-indigo-700", href="/admin/register") Register

  script.
    document.getElementById('login-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      var errEl = form.querySelector('.bg-red-50');
      btn.disabled = true;
      if (errEl) errEl.remove();
      fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: form.email.value, password: form.password.value })
      })
      .then(function(r) { return r.json().then(function(d) { return r.ok ? d : Promise.reject(d); }); })
      .then(function(data) {
        if (data.token) {
          localStorage.setItem('token', data.token);
          window.location.href = '/admin';
        }
      })
      .catch(function(err) {
        btn.disabled = false;
        var msg = document.createElement('div');
        msg.className = 'p-3 rounded-lg bg-red-50 text-red-700 text-sm';
        msg.textContent = err.message || 'Invalid credentials';
        form.insertBefore(msg, form.firstChild);
      });
    });
